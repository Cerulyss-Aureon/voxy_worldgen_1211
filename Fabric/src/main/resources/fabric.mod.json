{
  "schemaVersion": 1,
  "id": "voxyworldgen",
  "version": "${version}",
  "name": "Voxy World Gen",
  "description": "This mod generates chunks passively around players, offline or online, and the worldspawn to generate chunks that will most likely be needed in the near future. Integrates with Voxy for LOD generation.",
  "authors": [
    "iSeeEthan",
    "agnor99"
  ],
  "contact": {
    "sources": "https://github.com/iSeeEthan/voxy_distant_gen"
  },
  "accessWidener": "voxyworldgen.accesswidener",
  "__comment": "for quilt",
  "access_widener": "voxyworldgen.accesswidener",
  "license": "ARR",
  "icon": "pregen-logo.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "dev.iseeethan.voxyworldgen.VoxyWorldGenFabric"
    ]
  },
  "mixins": [
    "mixins.voxyworldgen.json"
  ],
  "depends": {
    "fabricloader": ">=0.16",
    "fabric": "*",
    "minecraft": "~1.21.11",
    "java": ">=21"
  }
}